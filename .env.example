# --- LLM (fully local, runs against an OpenAI-compatible Ollama endpoint) ---
# Point this at your Ollama server. A local instance or an SSH tunnel both work.
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen2.5-coder:14b
# Per-call timeout (ms) and max tokens for a single role/synth call.
LLM_TIMEOUT_MS=120000
LLM_MAX_TOKENS=2000

# --- Repos to analyze (JSON array) ---
# Each: name, path (local clone), oneLiner (product desc for the Growth role),
# competitors (optional CSV, used by the Growth role for positioning).
DIGEST_REPOS=[{"name":"my-app","path":"/path/to/my-app","oneLiner":"What this product does in one line","competitors":["CompetitorA","CompetitorB"]}]

# --- Output: Telegram (optional — leave blank to skip) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Output: Obsidian (optional — leave blank to skip) ---
OBSIDIAN_VAULT=/path/to/your/Obsidian Vault
# Subfolder under the vault for digest notes.
OBSIDIAN_DIGEST_DIR=dev-digest

# --- Context bounding ---
# Hard char budget for the repo digest fed to the local model (~4 chars/token).
CONTEXT_CHAR_BUDGET=48000
