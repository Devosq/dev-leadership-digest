# --- LLM (fully local, €0, nothing leaves VPS2) ---
# OpenAI-compatible Ollama endpoint. Use the SSH tunnel (http://127.0.0.1:11435/v1)
# or the Bearer-auth gateway (https://ai.example.com/v1).
OLLAMA_BASE_URL=http://127.0.0.1:11435/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen2.5-coder:14b
# Per-call timeout (ms) and max tokens for a single role/synth call.
LLM_TIMEOUT_MS=120000
LLM_MAX_TOKENS=2000

# --- Repos to analyze (JSON array) ---
# name, path (local clone), oneLiner (product desc for Growth role), competitors (CSV)
DIGEST_REPOS=[{"name":"Addwork","path":"C:/Users/<USERNAME>/dev/openclaw-backend","oneLiner":"Field-service / construction crew & client approval automation (WhatsApp + Telegram)","competitors":["Movenium","Zervant","Procore"]},{"name":"Xyven","path":"C:/Users/<USERNAME>/dev/trading-journal-app","oneLiner":"Trading journal + backtesting mobile app for futures/prop traders","competitors":["TraderSync","Tradezella","Edgewonk"]}]

# --- Output: Telegram (reuse an existing bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Output: Obsidian ---
OBSIDIAN_VAULT=C:/Users/<USERNAME>/OneDrive - OM Origo Oy/Tiedostot/Obsidian Vault
# Subfolder under the vault for digest notes.
OBSIDIAN_DIGEST_DIR=Strategia/dev-digest

# --- Context bounding ---
# Hard char budget for the repo digest fed to the local model (~4 chars/token).
CONTEXT_CHAR_BUDGET=48000
